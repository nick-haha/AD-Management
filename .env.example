HTTP_ADDR=:8080
FRONTEND_DIR=frontend
DB_PATH=ad-management.db

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-this-admin-password
ADMIN_SESSION_DURATION=12h
AD_DELETE_PROTECTED_ACCOUNTS=

# ── 凭据字段级加密（方案 B，强烈建议启用）──
# 加密 DB 中的 AD bindPassword 与飞书 appSecret（AES-256-GCM）。
# 留空 = 明文模式（向后兼容，不加密）。
# 生成密钥：openssl rand -base64 32
# 重要：密钥丢失后已加密的凭据无法解密，需重新配置域控/飞书密码；请妥善备份密钥。
AD_CRED_ENC_KEY=
