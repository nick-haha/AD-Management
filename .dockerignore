# 版本控制
.git
.gitignore
.gitattributes

# IDE / 编辑器
.vscode
.idea
.codebuddy
.workbuddy

# 环境变量（含敏感信息，不打入镜像）
.env
.env.*
*.local

# 数据库与日志（运行时生成，不打入镜像）
*.db
*.db-*
*.log
logs/
data/

# 编译产物（在容器内重新编译）
ad-server
ad-server.exe

# 文档与报告（非运行时需要）
*.md
README.md
DESIGN_SPEC.md
*_REPORT.md
*_FIX_REPORT*.md
overview.md
pwd-expiry-fix-overview.md

# 系统文件
.DS_Store
Thumbs.db

# 临时与备份
*.bak
*.tmp
tmp/
